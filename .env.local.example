# ─────────────────────────────────────────────────────────────
# Nohoras Dream — variables de entorno
# Copia este archivo a .env.local y rellena los valores.
# NUNCA commitees .env.local (está en .gitignore).
# Ver docs/04-arquitectura-tecnica.md
# ─────────────────────────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # llave maestra: solo server, jamás en el cliente

# Airbnb (Santa Marta)
AIRBNB_ICAL_SANTA_MARTA=https://www.airbnb.com/calendar/ical/1483618072090950324.ics
AIRBNB_LISTING_URL=https://airbnb.com/rooms/1483618072090950324

# Wompi (Girón)
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=          # validar firma de webhooks
WOMPI_INTEGRITY_SECRET=

# Notificaciones
WHATSAPP_TOKEN=               # Meta Cloud API
WHATSAPP_PHONE_ID=
RESEND_API_KEY=

# WhatsApp directo (Santa Marta CTA)
WHATSAPP_NUMERO_SANTA_MARTA=57
